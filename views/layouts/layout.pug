doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Fotaza 2 - #{title}
    link(rel="stylesheet", href="/css/style.css")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/")
          i.bi.bi-camera.me-2
          | Fotaza 2
        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        .collapse.navbar-collapse(id="navbarNav")
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/")
                i.bi.bi-house.me-1
                | Inicio
            if currentUser
              li.nav-item
                a.nav-link(href="/posts/create")
                  i.bi.bi-plus-circle.me-1
                  | Publicar
              li.nav-item
                a.nav-link(href="/users/feed")
                  i.bi.bi-newspaper.me-1
                  | Siguiendo
              li.nav-item
                a.nav-link(href="/search")
                  i.bi.bi-search.me-1
                  | Buscar
            else
              li.nav-item
                a.nav-link(href="/search")
                  i.bi.bi-search.me-1
                  | Buscar
          
          form.d-flex.me-3(action="/search", method="GET")
            input.form-control.me-2(type="search", name="q", placeholder="Buscar...", aria-label="Buscar")
            button.btn.btn-outline-light(type="submit")
              i.bi.bi-search
          
          ul.navbar-nav
            if currentUser
              li.nav-item.dropdown
                a.nav-link.dropdown-toggle(href="#", role="button", data-bs-toggle="dropdown")
                  i.bi.bi-person-circle.me-1
                  | #{currentUser.username}
                ul.dropdown-menu.dropdown-menu-end
                  li
                    a.dropdown-item(href=`/users/${currentUser.id}`)
                      i.bi.bi-person.me-2
                      | Mi Perfil
                  li
                    a.dropdown-item(href="/users/collections")
                      i.bi.bi-bookmark-star.me-2
                      | Mis Colecciones
                  li
                    a.dropdown-item(href="/users/notifications")
                      i.bi.bi-bell.me-2
                      | Notificaciones
                      span#unread-badge.badge.bg-danger.ms-2(style="display:none") 0
                  li
                    a.dropdown-item(href="/users/messages")
                      i.bi.bi-envelope.me-2
                      | Mensajes
                  li
                    hr.dropdown-divider
                  if isAdmin || isValidator
                    li
                      a.dropdown-item(href="/admin/reports")
                        i.bi.bi-flag.me-2
                        | Moderación
                    li
                      hr.dropdown-divider
                  li
                    a.dropdown-item(href="/logout")
                      i.bi.bi-box-arrow-right.me-2
                      | Cerrar sesión
            else
              li.nav-item
                a.nav-link(href="/login")
                  i.bi.bi-box-arrow-in-right.me-1
                  | Iniciar sesión
              li.nav-item
                a.nav-link(href="/register")
                  i.bi.bi-person-plus.me-1
                  | Registrarse

    .container.mt-4
      block content

    footer.mt-5.py-3.text-center.text-muted.border-top
      .container
        small &copy; #{new Date().getFullYear()} Fotaza 2 - Comparte y vende tus fotografías

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="/js/main.js")
    
    script.
      async function updateUnreadCount() {
        try {
          const response = await fetch('/api/notifications/unread-count');
          const data = await response.json();
          const badge = document.getElementById('unread-badge');
          if (data.count > 0) {
            badge.textContent = data.count > 99 ? '99+' : data.count;
            badge.style.display = 'inline-block';
          } else {
            badge.style.display = 'none';
          }
        } catch (error) {
          console.error('Error:', error);
        }
      }
      
      if (document.getElementById('unread-badge')) {
        updateUnreadCount();
        setInterval(updateUnreadCount, 30000);
      }
