extends ../layouts/layout

block content
  .row.justify-content-center
    .col-md-8.col-lg-7
      .card.shadow
        .card-header.bg-primary.text-white
          h4.mb-0
            i.bi.bi-plus-circle.me-2
            | Crear nueva publicación
        .card-body
          if error
            .alert.alert-danger= error
          
          form(method="POST", action="/posts", enctype="multipart/form-data")
            .mb-3
              label.form-label(for="title") Título *
              input.form-control(type="text", name="title", id="title", required, placeholder="Un título descriptivo")
            
            .mb-3
              label.form-label(for="description") Descripción
              textarea.form-control(name="description", id="description", rows="4", placeholder="Describe tu publicación...")
            
            .mb-3
              label.form-label(for="genre") Género *
              select.form-control(name="genre", id="genre", required)
                option(value="") Seleccionar género...
                each genre in genres
                  option(value=genre)= genre.charAt(0).toUpperCase() + genre.slice(1)
            
            .mb-3
              label.form-label(for="tags") Etiquetas
              input.form-control(type="text", name="tags", id="tags", placeholder="paisaje, naturaleza, montaña (separadas por comas)")
              .form-text.text-muted Las etiquetas ayudan a que otros encuentren tu contenido
            
            .mb-3
              label.form-label(for="media") Imágenes o Videos *
              input.form-control(type="file", name="media", id="media", accept="image/*,video/*", multiple, required)
              .form-text.text-muted Puedes subir imágenes (jpg, png, gif, webp) o videos (mp4, webm, ogg). Máx. 10 archivos.
              #mediaPreview.mt-2.d-flex.flex-wrap
            
            .mb-3
              label.form-label(for="license") Licencia *
              select.form-control(name="license", id="licenseSelect", required)
                option(value="free") Sin copyright (libre para uso)
                option(value="copyright") Copyright (con marca de agua)
            
            .mb-3(id="watermarkGroup", style="display: none;")
              label.form-label(for="watermark") Texto para marca de agua
              input.form-control(type="text", name="watermark", id="watermark", placeholder="Ej: © MiNombre - fotaza2.com")
              .form-text.text-muted Este texto aparecerá en la esquina inferior derecha de la imagen
            
            hr
            .d-flex.justify-content-between
              a.btn.btn-secondary(href="/")
                i.bi.bi-arrow-left.me-1
                | Cancelar
              button.btn.btn-primary(type="submit")
                i.bi.bi-cloud-upload.me-1
                | Publicar

  script.
    const licenseSelect = document.getElementById('licenseSelect');
    const watermarkGroup = document.getElementById('watermarkGroup');
    
    if (licenseSelect && watermarkGroup) {
      licenseSelect.addEventListener('change', function() {
        watermarkGroup.style.display = this.value === 'copyright' ? 'block' : 'none';
      });
    }
    
    const mediaInput = document.getElementById('media');
    if (mediaInput) {
      mediaInput.addEventListener('change', function(e) {
        const preview = document.getElementById('mediaPreview');
        if (preview) {
          preview.innerHTML = '';
          const files = Array.from(this.files);
          files.forEach(file => {
            const isVideo = file.type.startsWith('video/');
            const container = document.createElement('div');
            container.style.width = '100px';
            container.style.margin = '5px';
            container.style.position = 'relative';
            
            if (isVideo) {
              const video = document.createElement('video');
              video.src = URL.createObjectURL(file);
              video.style.width = '100%';
              video.style.height = '80px';
              video.style.objectFit = 'cover';
              video.style.borderRadius = '4px';
              container.appendChild(video);
              
              const icon = document.createElement('i');
              icon.className = 'bi bi-play-circle-fill';
              icon.style.position = 'absolute';
              icon.style.bottom = '5px';
              icon.style.right = '5px';
              icon.style.color = 'white';
              icon.style.backgroundColor = 'rgba(0,0,0,0.5)';
              icon.style.borderRadius = '50%';
              container.appendChild(icon);
            } else {
              const img = document.createElement('img');
              img.src = URL.createObjectURL(file);
              img.style.width = '100%';
              img.style.height = '80px';
              img.style.objectFit = 'cover';
              img.style.borderRadius = '4px';
              container.appendChild(img);
            }
            
            preview.appendChild(container);
          });
        }
      });
    }