extends ../layouts/layout

block content
  .row
    .col-12
      .d-flex.justify-content-between.align-items-center.mb-4
        h2
          i.bi.bi-flag.me-2
          | Denuncias pendientes
        a.btn.btn-outline-secondary(href="/admin/stats")
          i.bi.bi-graph-up.me-1
          | Estadísticas
      
      if reports && reports.length
        .table-responsive
          table.table.table-hover
            thead.table-dark
              tr
                th ID
                th Tipo
                th Denunciante
                th Motivo
                th Fecha
                th Acciones
            tbody
              each report in reports
                tr
                  td= report.id
                  td
                    if report.post_id
                      span.badge.bg-warning Publicación
                    else
                      span.badge.bg-info Comentario
                  td= report.reporter_username
                  td= report.reason
                  td= new Date(report.created_at).toLocaleDateString()
                  td
                    a.btn.btn-sm.btn-primary(href=`/admin/reports/${report.id}`)
                      i.bi.bi-eye.me-1
                      | Revisar
      else
        .alert.alert-success.text-center
          i.bi.bi-check-circle.me-2
          | No hay denuncias pendientes. ¡Todo en orden!
