extends ../layouts/layout

block content
  .row
    .col-12
      .d-flex.justify-content-between.align-items-center.mb-4
        h2
          i.bi.bi-flag.me-2
          | Denuncias pendientes
        .btn-group
          a.btn.btn-outline-secondary(href="/admin/stats")
            i.bi.bi-graph-up.me-1
            | Estadísticas
          a.btn.btn-outline-danger(href="/admin/banned-users")
            i.bi.bi-person-x.me-1
            | Usuarios inactivos
      
      if reports && reports.length
        .table-responsive
          table.table.table-hover
            thead.table-dark
              tr
                th ID
                th Tipo
                th Denunciante
                th Contenido
                th Motivo
                th Fecha
                th Acciones
            tbody
              each report in reports
                tr
                  td= report.id
                  td
                    if report.type === 'comment' || report.comment_id
                      span.badge.bg-info Comentario
                    else
                      span.badge.bg-warning Publicación
                  td= report.reporter_username
                  td
                    if report.comment_content
                      | #{report.comment_content ? report.comment_content.substring(0, 50) : 'Contenido no disponible'}...
                    else
                      | #{report.post_title ? report.post_title.substring(0, 50) : 'Publicación'}...
                  td= report.reason
                  td= new Date(report.created_at).toLocaleDateString()
                  td
                    a.btn.btn-sm.btn-primary(href=`/admin/reports/${report.id}`)
                      i.bi.bi-eye.me-1
                      | Revisar
      else
        .alert.alert-success.text-center
          i.bi.bi-check-circle.me-2
          | No hay denuncias pendientes. ¡Todo en orden!
          br
          br
          a.btn.btn-outline-danger(href="/admin/banned-users")
            i.bi.bi-person-x.me-1
            | Ver usuarios inactivos
